# Sub-path where the app is served when deployed behind the gateway
# (used as vite `base` and as the react-router basename).
# Leave empty when the app is deployed standalone at the domain root.
VITE_WEB_CONTEXT=/monitor

# Backend API base URL, used only when running on localhost
# (or when VITE_FORCE_SERVICE_URL=true).
VITE_API_BASE_URL=http://localhost:8000/watchmen

# Set to "true" to force using VITE_API_BASE_URL even on non-localhost hosts.
# By default (not localhost), APIs are called via the same-origin "/watchmen" prefix,
# which the gateway proxies to the watchmen backend.
# VITE_FORCE_SERVICE_URL=false

# Optional UI toggles
# VITE_SHOW_ALERTS=false
# VITE_APP_TITLE=Watchmen Data Monitor
