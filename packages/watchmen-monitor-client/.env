# Enable/disable mock data mode (true/false)
VITE_USE_MOCK_DATA=false

# API base URL for real data fetching (watchmen-rest-doll)
VITE_API_BASE_URL=http://localhost:3030/watchmen

# Router basename (web context path)
VITE_WEB_CONTEXT=/

# Force using VITE_API_BASE_URL even in non-localhost (true/false)
VITE_FORCE_SERVICE_URL=false

# App title displayed in sidebar header
VITE_APP_TITLE=Watchmen Data Monitor

# Feature flags for not-yet-implemented consoles (driven by other services)
VITE_SHOW_ALERTS=false
VITE_SHOW_GLOBAL_MAP=false
