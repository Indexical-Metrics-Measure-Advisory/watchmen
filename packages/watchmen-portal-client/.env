# Backend API base URL for local development (used only on localhost).
# In production the backend is reached via the same-origin "/watchmen" prefix,
# which the gateway proxies to the watchmen server.
VITE_API_BASE_URL=http://localhost:3030/watchmen

# Sub-path where the app is served when deployed behind the gateway.
# For standalone deployment, leave as "/" (default).
# Example: VITE_WEB_CONTEXT=/portal
VITE_WEB_CONTEXT=/
