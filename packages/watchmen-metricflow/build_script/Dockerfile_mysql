FROM python:3.12.13-slim-trixie

WORKDIR /app
ADD . .
RUN pip install poetry && poetry config virtualenvs.create false && poetry install --without dev -vv -E mysql -E trino -E rabbit -E s3 -E collector

EXPOSE 8910
CMD ["uvicorn","watchmen_metricflow.main:app","--host", "0.0.0.0", "--port", "8910"]






