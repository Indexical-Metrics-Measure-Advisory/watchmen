# Sub-path where the app is served when deployed behind the gateway
# (used as vite `base` and as the react-router basename).
# Leave empty when the app is deployed standalone at the domain root.
VITE_WEB_CONTEXT=/dqc

# DQC API base URL (watchmen-rest-dqc), used only when running on localhost
# (or when VITE_FORCE_SERVICE_URL=true). Leave empty to call same-origin
# relative paths, which the vite dev server proxies (see vite.config.ts).
VITE_DQC_API_URL=http://localhost:8001

# Auth/admin API base URL (watchmen-rest-doll: /login, /token, /topic, /user),
# used only when running on localhost (or when VITE_FORCE_SERVICE_URL=true).
VITE_AUTH_API_URL=http://localhost:8000

# Set to "true" to force using the VITE_*_API_URL values even on non-localhost
# hosts. By default (not localhost), DQC APIs are called via the same-origin
# "/watchmen-dqc" prefix and auth/admin APIs via "/watchmen", which the
# gateway proxies to the corresponding backends.
# VITE_FORCE_SERVICE_URL=false

# PII classification feature toggle. Mirrors the backend
# PII_CLASSIFICATION_ENABLED setting of watchmen-rest-dqc; when not "true",
# the PII menu and page are hidden.
# VITE_PII_ENABLED=false
